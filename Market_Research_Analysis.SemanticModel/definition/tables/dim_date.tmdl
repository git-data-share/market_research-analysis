		level Date
			lineageTag: 7000f62d-6f0f-4ed8-9015-ea01e0b45b5a
			column: Date

	partition dim_date = calculated
		mode: import
		source =
				ADDCOLUMNS(
				    CALENDAR(MIN(fact_customer_activity[Dt_Customer]),
				    MAX(fact_customer_activity[Dt_Customer])
				    ),
				    "Year", YEAR([Date]),
				    "MonthNumber", MONTH([Date]),
				    "MonthName", FORMAT([Date],"MMM"),
				    "Quarter", "Q" & FORMAT([Date],"Q")
				)

	annotation PBI_Id = ec04e064c6684633bb7b3a7e37e6b073

